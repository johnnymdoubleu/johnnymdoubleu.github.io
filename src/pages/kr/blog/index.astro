---
import Layout from "@layouts/Layout.astro";
import BlogHeader from "@components/blog/BlogHeader.astro";
import Container from "@components/Container.astro";
import HeroImage from "@components/blog/HeroImage.astro";
import { getCollection } from "astro:content";

const locale = "kr";
const posts = (await getCollection("blog", (entry) => entry.id.startsWith(`${locale}/`)))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((post) => ({
    ...post,
    href: `/kr/blog/${post.id.slice(locale.length + 1)}/`,
  }));
---

<Layout title="Blog">
  <Container class="pt-16">
    <ul class="m-0 grid list-none grid-cols-2 gap-6 p-0">
      {
        posts.map((post, index) => (
          <li class={`${index === 0 ? "col-span-2 mb-4 w-full text-center" : ""}`}>
            <a href={post.href} class="block transition-colors duration-200">
              <HeroImage
                class={`${index === 0 ? "w-full" : ""} mb-2 rounded-lg hover:shadow-md`}
                src={post.data.heroImage}
                alt={post.data.title}
                width={720}
                height={360}
              />
              <BlogHeader
                pubDate={post.data.pubDate}
                name={`title-${post.data.title}`}
                isSubheading={true}
                class={`${index === 0 ? "text-xl md:text-2xl lg:text-3xl" : ""} m-0`}>
                {post.data.title}
              </BlogHeader>
            </a>
          </li>
        ))
      }
    </ul>
  </Container>
</Layout>
