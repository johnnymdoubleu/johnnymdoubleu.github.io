---
// import translations
import translations from "@utils/t.ts";
import Layout from "@layouts/Layout.astro";
import Container from "@src/components/Container.astro";
import { Image } from 'astro:assets';
import frontimage from '../assets/images/front/edin-frontpage.jpg';

const t = translations(Astro.url);

const newsItems = [
	{
		date: "July 2026",
		title: "Best Poster Award @ ISBA 2026",
		description:
			"I presented Kolmogorov–Arnold Neural Model with Picking-and-Pruning Prior and received the Best Poster Award at the ISBA World Meeting 2026 in Nagoya, Japan.",
		icon: "🏆"},
	{
		date: "July 2026",
		title: "Junior Research Travel Award @ ISBA 2026",
		description:
			"I was awarded a Junior Research Travel Award at the ISBA World Meeting 2026 in Nagoya, Japan.",
		icon: "✈️"}];
---



<Layout>
	<Container class="pt-16 lg:grid grid-cols-3 gap-4">
		<div class="lg:col-span-2">
			<Image class="float-right w-5/12 m-3 rounded-md md:w-3/12 lg:hidden" src={frontimage} alt="Me at Meadows"/>
			<span set:html={t.home_description} />
		</div>
		<div class="lg:col-span-1">
			<Image class="hidden lg:block rounded-md" src={frontimage} alt="Me at Meadows"/>
		</div>
	</Container>

	<Container class="pt-10 md:grid md:grid-cols-2 lg:pt-1 lg:grid lg:grid-cols-2 gap-7">
		<div class="pb-5 lg:justify-items-center">
			<span set:html={t.interest}/>
		</div>
		<div class="lg:justify-items-center">
			<span set:html={t.education}/>
		</div>
	</Container>

<!-- News section -->
	<Container class="pt-10">
		<section aria-labelledby="news-heading">
			<div class="mb-5 flex items-center gap-3">
				<h2 id="news-heading" class="text-xl font-semibold tracking-wide text-stone-800 dark:text-stone-100" > Latest News </h2>
				<div class="h-px flex-1 bg-stone-300 dark:bg-stone-600" aria-hidden="true" ></div>
			</div>

			<div class="grid gap-4 md:grid-cols-2">
				{
					newsItems.map((item) => (
						<article
							class="rounded-lg border border-stone-200 bg-white p-5 shadow-sm transition duration-200 hover:-translate-y-0.5 hover:shadow-md dark:border-stone-600 dark:bg-stone-700">
							<div class="flex items-start gap-4">
								<span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-stone-100 text-xl dark:bg-stone-600" aria-hidden="true"> {item.icon} </span>

								<div>
									<p class="mb-1 text-sm font-medium  tracking-wide text-stone-500 dark:text-stone-300"> {item.date} </p>
									<h3 class="mb-2 font-semibold text-stone-800 dark:text-stone-50"> {item.title} </h3>
									<p class="leading-relaxed text-stone-600 dark:text-stone-200"> {item.description} </p>
								</div>
							</div>
						</article>))}
			</div>
		</section>
	</Container>	
	<Container class="pt-5 lg:pt-1">
		<blockquote class="saying">
			<p set:html={t.quote_description}/>
		</blockquote>
	</Container>
	<!-- <script type="text/javascript" id="clstr_globe" src="//clustrmaps.com/globe.js?d=06Km3jTn3k6LxdNaWxkPxDXBrLK2rrCbu1OpBBUj5mg&w=300"></script> -->
	<!-- <script type='text/javascript' id='clustrmaps' src='//cdn.clustrmaps.com/map_v2.js?cl=292524&w=400&t=tt&d=06Km3jTn3k6LxdNaWxkPxDXBrLK2rrCbu1OpBBUj5mg&co=fafaf9&ct=808080&cmo=3acc3a&cmn=ff5353'></script> -->
</Layout>
