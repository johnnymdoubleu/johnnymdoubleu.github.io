---
import { getLocale } from "@utils/i18n";
import { ClientRouter } from "astro:transitions";
import BaseHead from "@components/BaseHead.astro";
import Navbar from "@components/Navbar.astro";
import Footer from "@components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "@src/consts";
import "@fontsource/raleway";

const locale = getLocale(Astro.url);
const buildDate = new Date(__DATE__);

type Props = {
  title?: string;
  description?: string;
  image?: string;
};

const { image, title = SITE_TITLE, description = SITE_DESCRIPTION } = Astro.props as Props;
---

<html lang={locale}>
  <head>
    <BaseHead title={title} description={description} image={image} />
    <!-- Comment the line below if you want to remove client-side routing. -->
    <ClientRouter />
    <script
      is:inline
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1682309227131967"
      crossorigin="anonymous"></script>
  </head>
  <body>
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer {buildDate} />
    <script
      is:inline
      type="text/partytown"
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-YXB2RPP5CR"></script>
    <script is:inline type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-YXB2RPP5CR');
    </script>
  </body>
</html>
